# =============================================================
# SmartLock Frontend — Environment Variables Template
# =============================================================
# Sao chép file này thành .env.local rồi điền giá trị thực tế
#   cp .env.example .env.local
# =============================================================

# ------ Backend API (Server-side only) ----------------------
# URL gốc của backend API — dùng trong Next.js API Routes (BFF)
# KHÔNG có NEXT_PUBLIC_ vì chỉ chạy phía server
API_URL=https://giaothoatech.cloud/api

# ------ App (Client-side) -----------------------------------
# URL công khai của ứng dụng Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Node environment ------------------------------------
# "development" | "production" | "test"
NODE_ENV=development

COOKIE_FORCE_SECURE="true"
